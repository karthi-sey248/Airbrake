# ── Build outputs — generated by CI, never commit ────────────────────────────
backend/dist/
frontend/dist/
backend-python/package/
*.zip

# ── Dependencies ──────────────────────────────────────────────────────────────
backend/node_modules/
frontend/node_modules/
shared/node_modules/
node_modules/
backend-python/__pycache__/
backend-python/*.pyc
**/__pycache__/
*.pyc
.pytest_cache/

# ── Environment secrets — NEVER commit these ──────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Local development ─────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/airbrake_portal
# PORT=3001

# ── Lambda / Production ───────────────────────────────────────────────────────
# Set these as Lambda Environment Variables in the AWS Console, NOT in this file.
# DATABASE_URL=postgresql://USERNAME:PASSWORD@your-aurora-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/airbrake_portal

# Required for all environments
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/airbrake_portal
PORT=3001

# Teams incoming webhook URL (optional — alerts are silently skipped if not set)
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Jira integration (optional)
JIRA_BASE_URL=https://your-jira-instance.atlassian.net
JIRA_PROJECT_KEY=AI
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token

# API key for POST /api/ingest/* (optional — open in dev if not set)
API_KEY=

# Airbrake integration (optional)
AIRBRAKE_API_KEY=
AIRBRAKE_PROJECT_ID=
AIRBRAKE_POLL_INTERVAL=30000

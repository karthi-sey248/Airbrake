{
  "name": "@portal/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:lambda": "tsc",
    "deploy:zip": "tsc && powershell Compress-Archive -Path dist,node_modules,package.json -DestinationPath lambda-deploy.zip -Force",
    "start": "node dist/index.js",
    "start:lambda": "node dist/lambda.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --coverage --watchAll=false",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1062.0",
    "@aws-sdk/dsql-signer": "^3.1062.0",
    "@aws/aurora-dsql-node-postgres-connector": "^0.1.9",
    "@portal/shared": "*",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "pg": "^8.11.0",
    "redis": "^4.7.1",
    "serverless-http": "3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
